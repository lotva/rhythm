---
import '../styles/index.css'
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width"
		/>

		<link
			rel="icon"
			type="image/svg+xml"
			href="/favicon.svg"
		/>
		<link
			rel="icon"
			href="/favicon.ico"
		/>

		<meta
			name="generator"
			content={Astro.generator}
		/>

		<title>Rhythm</title>
	</head>

	<body>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	html {
		cursor: default;
	}

	body {
		position: relative;
		max-inline-size: 64ch;
		margin: 0 auto;
	}

	main {
		padding: gap(10) gap();
	}
</style>
